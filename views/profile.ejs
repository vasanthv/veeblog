<!doctype html>
<html lang="en">
<%- include('partials/html-head', {title: profile.name ?? profile.username}); -%>

<body>
  <div id="app" class="wrap">
    <%- include('partials/profile-header', {title: profile.name ?? profile.username}); -%>

    <% if(typeof profile.bio !== "undefined") { %>
    <% if(profile.bio !== "") { %>
    <section class="bio"><%- profile.bioHTML %></section>
    <% } %>
    <% } %>

    <%- include('partials/posts'); -%>
    <%- include('partials/pagination'); -%>
    <%- include('partials/profile-footer'); -%>
  </div>
</body>

</html>